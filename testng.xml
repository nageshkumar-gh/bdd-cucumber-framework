<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<!--
  TestNG suite used by Maven Surefire.

  Why this exists:
  - It is the executable entry point for `mvn test` in this framework.
  - It lets us control which runner(s) execute without relying on classpath scanning.
  - Later phases will add parallelism and additional suites (smoke/regression).
-->
<suite name="BDD Cucumber Framework - Smoke Suite" verbose="1" parallel="false">
    <test name="Smoke Tests (@smoke)">
        <classes>
            <class name="com.framework.runners.TestRunner"/>
        </classes>
    </test>
</suite>

