<?xml version="1.0" encoding="UTF-8"?>
<!--
  Log4j2 configuration for test execution.

  Why this file lives under src/test/resources:
  - It configures logging for the test classpath (Surefire) without affecting production packaging assumptions.
  - It keeps local + CI behavior consistent: console for humans, rolling file for post-mortems.

  Why rolling file under target/:
  - target/ is already treated as disposable build output, which makes log retention predictable in CI artifacts.
-->
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <!-- Why property indirection: lets us reuse the same pattern in multiple appenders without drift. -->
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %logger{36} - %msg%n</Property>
        <!--
          Log directory resolution:
          - Maven Surefire sets -Dframework.log.dir to an absolute path (${project.build.directory}/logs).
          - IDE runs typically omit that; we fall back to ${user.dir}/target/logs so logs still land under
            the project when the run configuration's working directory is the module root (IntelliJ default).
          - Override anytime: -Dframework.log.dir=/absolute/path/to/logs
        -->
        <Property name="LOG_DIR">${sys:framework.log.dir:-${sys:user.dir}/target/logs}</Property>
    </Properties>

    <Appenders>
        <!-- Console is the fastest feedback loop during local debugging and CI tailing. -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- Rolling file gives us durable evidence across reruns without unbounded disk growth. -->
        <RollingFile name="RollingFile"
                     fileName="${LOG_DIR}/framework.log"
                     filePattern="${LOG_DIR}/framework-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <!-- Why time + size: prevents huge single files while still allowing daily rotation in CI. -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="14"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Selenium can be chatty; WARN keeps signal high without hiding real errors. -->
        <Logger name="org.openqa.selenium" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <!-- WebDriverManager can spam download logs; INFO is usually enough for troubleshooting. -->
        <Logger name="io.github.bonigarcia" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <!-- Framework code should be informative by default. -->
        <Logger name="com.framework" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
    </Loggers>
</Configuration>
